# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Model to use for all agents. Groq's free tier has generous rate limits
# on these. See https://console.groq.com/docs/models for the current list.
GROQ_MODEL=groq/llama-3.3-70b-versatile

# Port the app listens on locally (Render sets its own PORT automatically)
PORT=8000
